<!-- Views/add-product.ejs -->
<form action="/" method="post" id="form-container" class="row g-3 my-3 p-3">
    <fieldset>
        <legend class="text-center mb-3">Add New Product</legend>
        <div class="col-12 mb-3">
            <label for="name" class="form-label">Product name</label>
            <input type="text" class="form-control" id="name" name="name" required>
        </div>
        <div class="col-12 mb-3">
            <label for="desc" class="form-label">Product Description</label>
            <textarea name="desc" class="form-control" id="desc" name="desc" required></textarea>
        </div>
        <div class="col-12 mb-3">
            <label for="price" class="form-label">Price</label>
            <input type="number" name="price" class="form-control" id="price" required>
        </div>
        <div class="col-12 mb-4">
            <label for="imageURL" class="form-label">Image URL</label>
            <input type="url" class="form-control" id="imageURL" name="imageURL" required>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Add Product</button>
        </div>
    </fieldset>
</form>