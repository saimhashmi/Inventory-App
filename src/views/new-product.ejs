<!-- Views/add-product.ejs -->

<h1 class="text-center mb-3">Add New Product</h1>

<form action="/products" method="post" id="form-container" class="row g-3 my-3 p-3">
    <% if (errorMessages) { %>
        <% errorMessages.forEach(error => { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error.msg %>
            </div>
        <% }); %>
    <% } %>
    <div class="col-12 mb-3">
        <label for="name" class="form-label">Product name</label>
        <input type="text" class="form-control" id="name" name="name">
    </div>
    <div class="col-12 mb-3">
        <label for="desc" class="form-label">Product Description</label>
        <textarea name="desc" class="form-control" id="desc" name="desc"></textarea>
    </div>
    <div class="col-12 mb-3">
        <label for="price" class="form-label">Price</label>
        <input type="number" name="price" class="form-control" id="price">
    </div>
    <div class="col-12 mb-4">
        <label for="imageURL" class="form-label">Image URL</label>
        <input type="url" class="form-control" id="imageURL" name="imageURL">
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Add Product</button>
    </div>
</form>