<!-- Views/add-product.ejs -->

<h1 class="text-center my-3">Update Product</h1>

<form action="/update-product/<%= product.id %>" method="post" id="form-container" class="row g-3 my-3 p-3">
    <% if (errorMessages) { %>
        <% errorMessages.forEach(error => { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error.msg %>
            </div>
        <% }); %>
    <% } %>

    <div class="col-12 mb-3">
        <!-- <label for="id" class="form-label">Product ID</label> -->
        <input type="hidden" class="form-control" id="id" name="id" value="<%= product.id %>">
    </div>
    <div class="col-12 mb-3">
        <label for="name" class="form-label">Product name</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>">
    </div>
    <div class="col-12 mb-3">
        <label for="desc" class="form-label">Product Description</label>
        <textarea name="desc" class="form-control" id="desc" name="desc" ><%= product.desc %></textarea>
    </div>
    <div class="col-12 mb-3">
        <label for="price" class="form-label">Price</label>
        <input type="number" name="price" class="form-control" id="price" step="0.01" value="<%= product.price %>">
    </div>
    <div class="col-12 mb-4">
        <label for="imageURL" class="form-label">Image URL</label>
        <input type="url" class="form-control" id="imageURL" name="imageURL" value="<%= product.imageUrl %>">
    </div>
    <div class="col-12 mb-3">
        <!-- <label for="id" class="form-label">Product ID</label> -->
        <input type="hidden" class="form-control" id="imageAlt" name="imageAlt" value="<%= product.imageAlt %>">
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Update Product</button>
    </div>
</form>